{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(.stagix/**)",
      "Bash(npm run test *)",
      "Bash(npm run lint *)",
      "Bash(npx *)",
      "Bash(python -m pytest *)",
      "Bash(ruff check *)",
      "Bash(go test *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(.stagix/.env)"
    ]
  }
}
